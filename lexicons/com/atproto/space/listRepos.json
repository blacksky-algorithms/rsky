{
  "lexicon": 1,
  "id": "com.atproto.space.listRepos",
  "defs": {
    "main": {
      "type": "query",
      "description": "List the known repos that hold data in a space (the writer set), with each repo's current rev and commit hash. Requires a space credential; implemented by a space host.",
      "parameters": {
        "type": "params",
        "required": ["space"],
        "properties": {
          "space": {
            "type": "string",
            "description": "Permissioned space URI, in the form at://{authority}/space/{spaceType}/{skey}. Not a standard at-uri."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000,
            "default": 500
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["repos"],
          "properties": {
            "cursor": { "type": "string" },
            "repos": {
              "type": "array",
              "items": { "type": "ref", "ref": "com.atproto.space.defs#repoRef" }
            }
          }
        }
      },
      "errors": [{ "name": "SpaceNotFound" }]
    }
  }
}
